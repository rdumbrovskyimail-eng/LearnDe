<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <!-- API KEY INPUT — скрывается после сохранения ключа -->
    <LinearLayout
        android:id="@+id/keyInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="#1A000000"
        android:visibility="visible">

        <EditText
            android:id="@+id/apiKeyEditText"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Gemini API Key"
            android:inputType="textPassword"
            android:textSize="13sp"
            android:textColor="?colorOnSurface"
            android:textColorHint="#88888888"
            android:background="@android:drawable/edit_text"
            android:paddingHorizontal="10dp"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:fontFamily="monospace" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/keyOkButton"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:text="OK"
            android:textAllCaps="false"
            android:minWidth="56dp" />

    </LinearLayout>

    <View
        android:id="@+id/keyDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20000000"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/statusIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/presence_busy"
            android:contentDescription="Connection status"
            tools:tint="#F44336" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Disconnected"
            android:textColor="?colorOnSurface"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20000000" />

    <ScrollView
        android:id="@+id/logScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <TextView
            android:id="@+id/chatLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:textColor="?colorOnSurface"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:text=""
            android:gravity="bottom"
            android:textIsSelectable="true" />
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20000000" />

    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startButton"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Start"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stopButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:text="Stop"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveLogButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Save"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>