<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Сеть: WebSocket (OkHttp) + reconnect -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Микрофон: AudioRecord (VOICE_COMMUNICATION) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Аудио: AcousticEchoCanceler + VOICE_COMMUNICATION AudioSource -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Foreground Service: микрофон в фоне (Android 14+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Уведомления: показ нотификации Foreground Service (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Фильтрация Google Play: отсечь устройства без микрофона -->
    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <application
        android:name=".GeminiLiveApplication"
        android:allowBackup="false"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:enableOnBackInvokedCallback="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|density"
            android:windowSoftInputMode="adjustResize"
            tools:ignore="LockedOrientationActivity">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground Service: запись микрофона при свёрнутом приложении -->
        <service
            android:name=".GeminiLiveForegroundService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

    </application>

</manifest>